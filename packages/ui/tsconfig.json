{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler" ,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "jsx": "react-jsx",
        "rootDir": ".",
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "resolvePackageJsonImports": true,
        "ignoreDeprecations": "6.0"    
    }
}