{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": ["node"],
        "rootDir": ".",
        "outDir": "dist",
        "jsx": "react-jsx",
        "paths": {
            "@backend/*": ["./*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "drizzle.config.ts"],
    "exclude": ["node_modules", "dist"]
}