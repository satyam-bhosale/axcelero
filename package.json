{
  "name": "axcelero",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@axcelero/backend",
    "dev:admin": "turbo run dev --filter=@axcelero/admin",
    "dev:web": "turbo run dev --filter=@axcelero/web",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=@axcelero/backend",
    "build:admin": "turbo run build --filter=@axcelero/admin",
    "build:web": "turbo run build --filter=@axcelero/web",
    "build:utils": "turbo run build --filter=@axcelero/utils",
    "build:constants": "turbo run build --filter=@axcelero/constants",
    "start:backend": "turbo run start --filter=@axcelero/backend",
    "devtools": "turbo devtools --port=3003"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "tsup": "catalog:",
    "turbo": "2.9.18",
    "typescript": "catalog:"
  }
}